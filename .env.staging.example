DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# Render service hostname, for example: shopback-staging.onrender.com
DJANGO_ALLOWED_HOSTS=replace-backend-hostname

# Render Postgres internal connection string
DATABASE_URL=postgresql://user:password@host:5432/database

# Media uploads go to Cloudinary on staging. Keep this disabled locally.
USE_CLOUDINARY_MEDIA=True
CLOUDINARY_CLOUD_NAME=replace-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-cloudinary-api-secret

# Frontend URL, for example: https://shopfront-staging.vercel.app
FRONTEND_BASE_URL=https://replace-frontend-hostname
CORS_ALLOWED_ORIGINS=https://replace-frontend-hostname
CSRF_TRUSTED_ORIGINS=https://replace-frontend-hostname

# Browser traffic can go through the Nuxt /api proxy, so the default Lax mode is enough.
# Only override these if you intentionally call the backend directly from the browser.
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
# Optional if you want to silence Django's HSTS deploy warning on staging too:
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False

# Optional direct-browser mode for separate domains:
# API_COOKIE_SECURE=True
# API_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None

# Optional if you later use custom subdomains like staging.example.com + api-staging.example.com
# API_COOKIE_DOMAIN=.example.com
# CSRF_COOKIE_DOMAIN=.example.com
# SESSION_COOKIE_DOMAIN=.example.com

# Cart cleanup retention windows. These do nothing until you run `python manage.py cleanup_carts`.
CART_EMPTY_TTL_SECONDS=86400
CART_GUEST_TTL_SECONDS=2592000
CART_USER_TTL_SECONDS=5184000
BUY_NOW_SESSION_TTL_SECONDS=7200

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=replace-smtp-username
BREVO_SMTP_KEY=replace-smtp-password
DEFAULT_FROM_EMAIL=replace-from-email@example.com
CONTACT_NOTIFICATION_EMAIL=support@flexdrive.ge
BREVO_API_KEY=replace-brevo-api-key
BREVO_API_TIMEOUT=10

RECAPTCHA_SECRET_KEY=replace-recaptcha-secret
RECAPTCHA_ALLOWED_HOSTNAMES=replace-frontend-hostname

# EasyWay regional delivery quotes. Sender city must match the real pickup city.
EASYWAY_API_USER=replace-easyway-api-user
EASYWAY_API_KEY=replace-easyway-api-key
EASYWAY_API_BASE_URL=https://easyway.ge/api
EASYWAY_SENDER_NAME=replace-easyway-sender-name
EASYWAY_SENDER_TAX_CODE=replace-easyway-sender-tax-code
EASYWAY_SENDER_ADDRESS=replace-easyway-pickup-address
EASYWAY_SENDER_PHONE=replace-easyway-sender-phone
EASYWAY_SENDER_REGION_ID=24
EASYWAY_SENDER_CITY_ID=replace-with-easyway-city-id
EASYWAY_SENDER_LEGAL_FORM_ID=3
EASYWAY_RECEIVER_TAX_CODE_PLACEHOLDER=11111111111
EASYWAY_STANDARD_PACKAGE_ID=2
EASYWAY_DELIVERY_MARGIN_GEL=2.00
EASYWAY_INTERNAL_DELIVERY_PRICE_GEL=0.00
EASYWAY_QUOTE_MAX_AGE_SECONDS=900

# Meta Conversions API. Keep disabled until the token is set and server events are tested.
META_PIXEL_ID=replace-meta-pixel-id
META_CAPI_ACCESS_TOKEN=replace-meta-capi-token
META_CAPI_ENABLED=False
META_CAPI_GRAPH_API_VERSION=v25.0
META_CAPI_TIMEOUT_SECONDS=2
# Optional staging-only value from Meta Events Manager > Test events.
# Do not set this in production.
# META_CAPI_TEST_EVENT_CODE=TEST12345
